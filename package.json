{
  "name": "lotr-sdk",
  "version": "0.1.0",
  "description": "TypeScript client for The One API (Lord of the Rings)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx --env-file=.env demo/demo.ts",
    "diagnose": "tsx --env-file=.env demo/diagnose.ts"
  },
  "keywords": [
    "lotr",
    "lord-of-the-rings",
    "the-one-api",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
